---
export interface Props {
  images: { name: string; type: string; image: string }[];
}

const { images } = Astro.props;
---

<section id="galeri" class="px-4 py-20 bg-gray-50">
  <h2 class="text-[1.875rem] text-center mb-2">Koleksiyonumuz</h2>
  <p class="text-gray-600 text-center mb-12">Her gelin için özel tasarlanmış unik modeller</p>

  <div class="max-w-[1200px] mx-auto grid grid-cols-2 gap-6 lg:grid-cols-3">
    {images.map((img, i) => (
      <div
        class="relative overflow-hidden rounded-xl bg-white shadow-md cursor-pointer transition-shadow duration-300 hover:shadow-[0_20px_40px_rgba(0,0,0,0.2)]"
      >
        <img
          src={img.image}
          alt={`${img.name} - ${img.type}`}
          loading={i < 3 ? "eager" : "lazy"}
          class="block w-full aspect-[3/4] object-cover transition-transform duration-500 hover:scale-105"
        />
        <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent opacity-0 hover:opacity-100 transition-opacity duration-300 flex items-end p-4">
          <div>
            <h3 class="font-serif text-xl font-bold text-white">{img.name}</h3>
            <p class="text-sm text-white/90">{img.type}</p>
          </div>
        </div>
      </div>
    ))}
  </div>
</section>
